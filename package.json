{
  "name": "sstinnovationresort-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "%SystemRoot%\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/dev-reset.ps1",
    "dev:raw": "next dev --webpack",
    "dev:reset": "%SystemRoot%\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/dev-reset.ps1",
    "dev:stop": "%SystemRoot%\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/dev-stop.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test:contract:ui-alerts": "node scripts/test-ui-alerts-contract.js",
    "test:contract:ui-booking": "node scripts/test-ui-booking-contract.js",
    "test:contracts": "npm run test:contract:ui-alerts && npm run test:contract:ui-booking",
    "test:integration": "node scripts/test-integration-suite.js",
    "test": "npm run test:contracts && npm run test:integration",
    "smoke:rooms-zones": "node scripts/smoke-rooms-zones.js",
    "smoke:handoff": "node scripts/smoke-handoff.js",
    "smoke:platform-e2e": "node scripts/smoke-platform-e2e.js"
  },
  "dependencies": {
    "next": "16.2.4",
    "next-intl": "^4.11.0",
    "@swc/helpers": "0.5.21",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.38.0",
    "eslint-config-next": "16.2.4",
    "typescript": "^5.9.3"
  }
}
