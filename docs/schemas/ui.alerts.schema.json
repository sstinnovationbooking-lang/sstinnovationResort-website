{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sstinnovationresort.local/schemas/ui.alerts.schema.json",
  "title": "Site UI Alert Settings",
  "description": "Per-tenant UI alert controls from backend/central for lock popup and top banner notice.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "enabled": {
      "type": "boolean",
      "description": "Master switch for alerts on tenant website."
    },
    "mode": {
      "type": "string",
      "enum": ["none", "lock_maintenance", "lock_payment_overdue", "banner_maintenance"],
      "description": "Alert mode to display."
    },
    "noticeId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable identifier for this notice (used by frontend dismiss state)."
    },
    "title": {
      "$ref": "#/$defs/localizedText"
    },
    "message": {
      "$ref": "#/$defs/localizedText"
    },
    "description": {
      "$ref": "#/$defs/localizedText"
    },
    "bannerMessage": {
      "$ref": "#/$defs/localizedText"
    },
    "bannerDetail": {
      "$ref": "#/$defs/localizedText"
    },
    "dismissible": {
      "type": "boolean",
      "description": "Only applies to banner mode."
    },
    "buttons": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/button"
      },
      "maxItems": 3,
      "description": "Optional custom action buttons for lock popup."
    }
  },
  "required": ["mode"],
  "$defs": {
    "localizedText": {
      "description": "Localized text supports plain string or locale map (th-TH/en-US only).",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "th-TH": { "type": "string" },
            "en-US": { "type": "string" }
          },
          "minProperties": 1
        }
      ]
    },
    "button": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "$ref": "#/$defs/localizedText"
        },
        "href": {
          "type": "string",
          "minLength": 1
        },
        "style": {
          "type": "string",
          "enum": ["primary", "secondary"]
        }
      },
      "required": ["label"]
    }
  }
}
