CONTENT_MODE=static
DEFAULT_TENANT=forest-escape
BASE_DOMAIN=resort.local
TENANT_FALLBACK_POLICY=default
NEXT_PUBLIC_TEMPLATE_BOOKING_MOCK=true

# Used only when CONTENT_MODE=api
BACKEND_API_BASE_URL=https://backend.example.com
BACKEND_API_SECRET=replace-with-internal-secret
CENTRAL_API_BASE_URL=https://central.example.com
CENTRAL_API_SECRET=replace-with-central-secret

# Required backend endpoints (relative to BACKEND_API_BASE_URL):
# GET  /site/home
# GET  /site/rooms?checkIn=YYYY-MM-DD&nights=1..30
# POST /site/leads
# (Central fallback should support at least GET /site/home)

# BFF identity headers forwarded to backend:
# x-tenant-slug, x-tenant-id(resortId), x-resort-id, x-owner-id
# ownerId/resortId are configured in src/lib/tenants/registry.ts
